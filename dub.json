											 "/LIBPATH:$PACKAGE_DIR/app/jni/SDL_ttf/libtool/",
											 "/LIBPATH:$PACKAGE_DIR/app/jni/SDL_mixer/Release/",
											 "/LIBPATH:$PACKAGE_DIR/app/jni/assimp/build/lib",
											 "/LIBPATH:$PACKAGE_DIR/app/jni/shaderc/build/libshaderc/Release",
											 "/LIBPATH:$PACKAGE_DIR/app/jni/build/",
											 "/LIBPATH:C:/VulkanSDK/1.4.335.0/Lib"],
		"dflags-linux-dmd": ["-P-I/usr/include/SDL2/", "-P-I./deps/cimgui/", "-P-I./deps/libs/include/", "-P-I./deps/cimgui/imgui/", "-P-I./deps/assimp/build/include/", "-P-I./deps/assimp/include/"],
		"dflags-linux-ldc": ["-P-I/usr/include/SDL2/", "-P-I./deps/cimgui/", "-P-I./deps/libs/include/", "-P-I./deps/cimgui/imgui/", "-P-I./deps/assimp/build/include/", "-P-I./deps/assimp/include/"],
		"importPaths-gdc": ["/usr/include/SDL2/", "./deps/cimgui/", "./deps/cimgui/imgui/"],
		"lflags-linux": ["-L$PACKAGE_DIR", "-L./deps/assimp/build/bin/"],
		"copyFiles-windows":[ "$PACKAGE_DIR/app/jni/SDL2/build/SDL2.dll",
													"$PACKAGE_DIR/app/jni/SDL_image/build/SDL2_image.dll",
													"$PACKAGE_DIR/app/jni/SDL_image/build/external/libtiff/libtiff/tiff.dll",
													"$PACKAGE_DIR/app/jni/build/cimgui.dll",
													"$PACKAGE_DIR/app/jni/assimp/build/bin/assimp-vc142-mt.dll",
													"$PACKAGE_DIR/app/jni/shaderc/build/libshaderc/shaderc_shared.dll",
													"$PACKAGE_DIR/app/jni/shaderc/build/third_party/glslang/glslang/glslang.dll",
													"$PACKAGE_DIR/app/jni/shaderc/build/third_party/spirv-tools/source/SPIRV-Tools.dll",
													"$PACKAGE_DIR/app/jni/shaderc/build/third_party/spirv-tools/source/opt/SPIRV-Tools-opt.dll"],
	},
	{
		"name": "android-64",
		"targetType": "dynamicLibrary",
		"targetPath": "app/src/main/jniLibs/arm64-v8a",
		"targetName": "main",
		"preBuildCommands": [ "make -f Makefile.android clean", "make -f Makefile.android -j 8" ],
		"dflags-linux-ldc": ["-P-I$PACKAGE_DIR/app/jni/SDL2/include", 
