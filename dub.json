{
	"name": "dimgui",
	"targetName": "DImGui",
	"description": "An example of calling imgui from D.",
	"authors": ["Danny Arends"],
	"homepage": "http://www.dannyarends.nl",
	"copyright": "Copyright © 2025, Danny Arends",
	"license": "GPL-v3",
	"preBuildCommands-linux": [ "make -j 8" ],
	"preBuildCommands-windows-x86_64": [ "compile.bat" ],
	"configurations": [
	{
		"name": "default",
		"targetType": "executable",
		"platforms": ["linux", "windows"],
		"dflags-windows-x86_64": ["-P-IC:/VulkanSDK/1.4.309.0/Include", 
                              "-P-IC:/VulkanSDK/1.4.309.0/Include/SDL2", 
                              "-P-I./deps/cimgui/", "-P-I./deps/cimgui/imgui/"],
		"lflags-windows-x86_64": ["-LIBPATH:C:/VulkanSDK/1.4.309.0/Lib", "-LIBPATH:./", "SDL2main.lib", "SDL2.lib", "cimgui.lib", "vulkan-1.lib"],
		"dflags-linux": ["-P-I/usr/include/SDL2/", "-P-I./deps/cimgui/", "-P-I./deps/cimgui/imgui/"],
		"lflags-linux": ["-L./", "-lSDL2", "-lSDL2_ttf", "-lSDL2_image", "-lSDL2_mixer", "-lcimgui", "-lvulkan"]
	}
	]
}

