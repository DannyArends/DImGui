													"$PACKAGE_DIR/app/jni/SDL_ttf/libtool/SDL3_ttf.dll",
													"$PACKAGE_DIR/app/jni/SDL_mixer/Release/SDL3_mixer.dll",
													"$PACKAGE_DIR/app/jni/SDL_mixer/Release/external/libmpg123-build/ports/cmake/src/libmpg123/mpg123-0.dll",
													"$PACKAGE_DIR/app/jni/SDL_mixer/Release/external/libgme-build/gme/gme.dll",
													"$PACKAGE_DIR/app/jni/SDL_mixer/Release/external/wavpack-build/wavpackdll.dll",
													"$PACKAGE_DIR/app/jni/build/cimgui.dll",
													"$PACKAGE_DIR/app/jni/assimp/build/bin/assimp-vc142-mt.dll",
													"$PACKAGE_DIR/app/jni/shaderc/build/libshaderc/shaderc_shared.dll",
													"$PACKAGE_DIR/app/jni/shaderc/build/third_party/glslang/glslang/glslang.dll",
													"$PACKAGE_DIR/app/jni/shaderc/build/third_party/spirv-tools/source/SPIRV-Tools.dll",
													"$PACKAGE_DIR/app/jni/shaderc/build/third_party/spirv-tools/source/opt/SPIRV-Tools-opt.dll"],

		"dflags-linux": ["-P-I$PACKAGE_DIR/app/jni/SDL2/include",
										 "-P-I$PACKAGE_DIR/app/jni/cimgui/",
										 "-P-I$PACKAGE_DIR/app/jni/libs/include/",
										 "-P-I$PACKAGE_DIR/app/jni/cimgui/imgui/",
										 "-P-I$PACKAGE_DIR/app/jni/assimp/build/include/",
										 "-P-I$PACKAGE_DIR/app/jni/assimp/include/"],
		"lflags-linux": ["-L$PACKAGE_DIR/app/jni/SDL2/build/Release",
										 "-L$PACKAGE_DIR/app/jni/SDL_image/build/",
										 "-L$PACKAGE_DIR/app/jni/SDL_ttf/libtool/",
										 "-L$PACKAGE_DIR/app/jni/SDL_mixer/Release/",
										 "-L$PACKAGE_DIR/app/jni/assimp/build/lib",
										 "-L$PACKAGE_DIR/app/jni/shaderc/build/libshaderc/Release",
										 "-L$PACKAGE_DIR/app/jni/build/"],

	},
	{
		"name": "android-64",
		"targetType": "dynamicLibrary",
		"targetPath": "app/src/main/jniLibs/arm64-v8a",
		"targetName": "main",
		"preBuildCommands": [ "make -f Makefile.android clean", "make -f Makefile.android -j 8" ],
		"dflags-linux-ldc": ["-P-I$PACKAGE_DIR/app/jni/SDL2/include", 
                         "-P-I$PACKAGE_DIR/app/jni/SDL_ttf", 
                         "-P-I$PACKAGE_DIR/app/jni/SDL_image/include", 
                         "-P-I$PACKAGE_DIR/app/jni/SDL_mixer/include", 
                         "-P-I$PACKAGE_DIR/app/jni/shaderc/libshaderc/include/",
                         "-P-I$PACKAGE_DIR/app/jni/libs/include/",                         
                         "-P-I$PACKAGE_DIR/app/jni/build",
                         "-P-I~/Android/Sdk/ndk/27.2.12479018/toolchains/llvm/prebuilt/linux-x86_64/sysroot/usr/include", 
                         "-P-I./app/jni/cimgui/", "-P-I./app/jni/cimgui/imgui/",
                         "-P-I$PACKAGE_DIR/app/jni/assimp/build/include/", "-P-I$PACKAGE_DIR/app/jni/assimp/include/"],
		"lflags-linux": ["-L$PACKAGE_DIR", 
                     "-L$PACKAGE_DIR/app/build/intermediates/ndkBuild/debug/obj/local/arm64-v8a", 
                     "-L$PACKAGE_DIR/app/build/intermediates/cxx/Debug/5v1q0263/obj/local/arm64-v8a",
                     "-L$PACKAGE_DIR/deps/shaderc/build/libshaderc", 
                     "-L$PACKAGE_DIR/deps/spirv_cross/build", 
                     "-L$PACKAGE_DIR/app/src/main/jniLibs/arm64-v8a/", 
                     "-L/home/rqdt9/Android/Sdk/ndk/27.2.12479018/toolchains/llvm/prebuilt/linux-x86_64/sysroot/usr/lib/aarch64-linux-android/24", 
                     "-lSDL2","-lSDL2_image", "-lSDL2_mixer", "-lSDL2_ttf", "-lvulkan", "-lshaderc_shared", "-lspirv-cross-c-shared", "-lCImGui", "-lassimp"]
	}]
}

