{
	"name": "dimgui",
	"targetName": "DImGui",
	"description": "An example of calling imgui from D.",
	"authors": ["Danny Arends"],
	"homepage": "http://www.dannyarends.nl",
	"copyright": "Copyright © 2025, Danny Arends",
	"license": "GPL-v3",
	"preBuildCommands-linux": [ "make -j 8" ],
	"preBuildCommands-windows-x86_64": [ "compile.bat" ],
	"configurations": [
	{
		"name": "default",
		"targetType": "executable",
		"platforms": ["linux", "windows"],
		"dflags-windows-x86_64": ["-P-IC:/VulkanSDK/1.4.309.0/Include", 
                              "-P-IC:/VulkanSDK/1.4.309.0/Include/SDL2", 
                              "-P-I./deps/libs/include/", "-P-I./deps/cimgui/", "-P-I./deps/cimgui/imgui/"],
		"lflags-windows-x86_64": ["-LIBPATH:C:/VulkanSDK/1.4.309.0/Lib", 
                              "-LIBPATH:./", 
                              "-LIBPATH:./deps/libs/lib", 
                              "SDL2main.lib", "SDL2.lib", "SDL2_ttf.lib", "SDL2_mixer.lib", "SDL2_image.lib",
                              "cimgui.lib", "vulkan-1.lib"],
		"dflags-linux": ["-P-I/usr/include/SDL2/", "-P-I./deps/cimgui/", "-P-I./deps/cimgui/imgui/"],
		"lflags-linux": ["-L./", "-lSDL2", "-lSDL2_ttf", "-lSDL2_image", "-lSDL2_mixer", "-lcimgui", "-lvulkan"],
		"copyFiles-windows-x86_64": [
			"libs/lib/SDL2_image.dll",
			"libs/lib/SDL2_mixer.dll",
			"libs/lib/SDL2_ttf.dll",
			"libs/lib/optional/libavif-16.dll",
			"libs/lib/optional/libgme.dll",
			"libs/lib/optional/libogg-0.dll",
			"libs/lib/optional/libopus-0.dll",
			"libs/lib/optional/libopusfile-0.dll",
			"libs/lib/optional/libtiff-5.dll",
			"libs/lib/optional/libwavpack-1.dll",
			"libs/lib/optional/libwebp-7.dll",
			"libs/lib/optional/libwebpdemux-2.dll",
			"libs/lib/optional/libxmp.dll"
		],
	}
	]
}

