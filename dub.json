{
	"name": "dimgui",
	"targetName": "DImGui",
	"description": "An example of calling imgui from D.",
	"authors": ["Danny Arends"],
	"homepage": "http://www.dannyarends.nl",
	"copyright": "Copyright © 2025, Danny Arends",
	"license": "GPL-v3",
	"configurations": [
	{
		"name": "default",
		"targetType": "executable",
		"targetPath": "bin",
		"platforms": ["linux", "windows"],
		"libs-linux": ["SDL3", "SDL3_image", "SDL3_mixer", "SDL3_ttf", "CImGui", "vulkan", "shaderc_shared", "spirv-cross-c-shared", "assimp"],
		"libs-windows": ["SDL3", "SDL3_image", "SDL3_mixer", "SDL3_ttf", "CImGui", "vulkan-1", "shaderc_shared", "spirv-cross-c-shared", "assimp-vc142-mt"],
		"dflags": ["-P-I$PACKAGE_DIR/src/icons/",
							 "-P-I$PACKAGE_DIR/app/jni/SDL/include/",
							 "-P-I$PACKAGE_DIR/app/jni/SDL_image/include/",
							 "-P-I$PACKAGE_DIR/app/jni/SDL_ttf/include/",
							 "-P-I$PACKAGE_DIR/app/jni/SDL_mixer/include/",
							 "-P-I$PACKAGE_DIR/app/jni/assimp/include/",
							 "-P-I$PACKAGE_DIR/app/jni/assimp/build/include/",
							 "-P-I$PACKAGE_DIR/app/jni/shaderc/libshaderc/include/",
							 "-P-I$PACKAGE_DIR/app/jni/spirv_cross/include/",
							 "-P-I$PACKAGE_DIR/app/jni/cimgui/"],
		"dflags-windows": ["-P-IC:/VulkanSDK/1.4.335.0/Include"],
		"lflags-windows": ["/LIBPATH:$PACKAGE_DIR/app/jni/SDL/build/Release",
											 "/LIBPATH:$PACKAGE_DIR/app/jni/SDL_image/build/",
											 "/LIBPATH:$PACKAGE_DIR/app/jni/SDL_ttf/build/",
											 "/LIBPATH:$PACKAGE_DIR/app/jni/SDL_mixer/Release/",
											 "/LIBPATH:$PACKAGE_DIR/app/jni/assimp/build/lib",
											 "/LIBPATH:$PACKAGE_DIR/app/jni/shaderc/build/libshaderc/Release",
											 "/LIBPATH:$PACKAGE_DIR/app/jni/build/",
											 "/LIBPATH:C:/VulkanSDK/1.4.335.0/Lib"],
		"copyFiles-windows":[ "$PACKAGE_DIR/app/jni/SDL/build/SDL3.dll",
													"$PACKAGE_DIR/app/jni/SDL_image/build/SDL3_image.dll",
													"$PACKAGE_DIR/app/jni/SDL_ttf/build/SDL3_ttf.dll",
													"$PACKAGE_DIR/app/jni/SDL_mixer/Release/SDL3_mixer.dll",
													"$PACKAGE_DIR/app/jni/build/cimgui.dll",
													"$PACKAGE_DIR/app/jni/assimp/build/bin/assimp-vc142-mt.dll",
													"$PACKAGE_DIR/app/jni/shaderc/build/libshaderc/shaderc_shared.dll",
													"$PACKAGE_DIR/app/jni/shaderc/build/third_party/spirv-tools/source/SPIRV-Tools.dll",
													"$PACKAGE_DIR/app/jni/shaderc/build/third_party/spirv-tools/source/opt/SPIRV-Tools-opt.dll"],

		"lflags-linux": ["-L$PACKAGE_DIR/app/jni/SDL/build/Release",
										 "-L$PACKAGE_DIR/app/jni/SDL_image/build/",
										 "-L$PACKAGE_DIR/app/jni/SDL_ttf/build/",
										 "-L$PACKAGE_DIR/app/jni/SDL_mixer/Release/",
										 "-L$PACKAGE_DIR/app/jni/assimp/build/lib",
										 "-L$PACKAGE_DIR/app/jni/shaderc/build/libshaderc/Release",
										 "-L$PACKAGE_DIR/app/jni/build/"],
	},
	{
		"name": "android-64",
		"targetType": "dynamicLibrary",
		"targetPath": "app/src/main/jniLibs/arm64-v8a",
		"targetName": "main",
		"dflags": ["-P-D__builtin_va_list=void*",
							 "-P-D__alignof__(x)=__alignof(x)",
							 "-P-I$PACKAGE_DIR/src/icons/",
							 "-P-I$PACKAGE_DIR/app/jni/SDL/include/",
							 "-P-I$PACKAGE_DIR/app/jni/SDL_ttf/include/",
							 "-P-I$PACKAGE_DIR/app/jni/SDL_image/include/",
							 "-P-I$PACKAGE_DIR/app/jni/SDL_mixer/include/",
							 "-P-I$PACKAGE_DIR/app/jni/shaderc/libshaderc/include/",
							 "-P-I$PACKAGE_DIR/app/jni/",
							 "-P-I$PACKAGE_DIR/app/jni/cimgui/",
							 "-P-I$PACKAGE_DIR/app/jni/cimgui/imgui/",
							 "-P-I$PACKAGE_DIR/app/jni/assimp/include/",
							 "-P-I$PACKAGE_DIR/app/jni/assimp/build/include/"],
		"lflags": [ "-L$PACKAGE_DIR/app/build/intermediates/cxx/Release/9t656d2k/obj/arm64-v8a" ],
		"libs": ["SDL3", "SDL3_image", "SDL3_mixer", "SDL3_ttf", "vulkan", "shaderc_shared", "spirv-cross-c-shared", "cimgui", "assimp"]
	}
]
}

