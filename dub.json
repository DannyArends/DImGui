{
	"name": "dimgui",
	"targetName": "DImGui",
	"description": "An example of calling imgui from D.",
	"authors": ["Danny Arends"],
	"homepage": "http://www.dannyarends.nl",
	"copyright": "Copyright © 2025, Danny Arends",
	"license": "GPL-v3",
	"configurations": [
	{
		"name": "default",
		"targetType": "executable",
		"targetPath": "bin",
		"platforms": ["linux", "windows"],
		"libs-linux": ["SDL2", "SDL2_image", "SDL2_mixer", "SDL2_ttf", "CImGui", "vulkan", "shaderc_shared", "spirv-cross-c-shared", "assimp"],
		"libs-windows": ["SDL2main", "SDL2", "SDL2_image", "SDL2_mixer", "SDL2_ttf", "CImGui", "vulkan-1", "shaderc_shared", "spirv-cross-c-shared", "assimp-vc142-mt"],
		"dflags": ["-P-I$PACKAGE_DIR/src/icons/",
