name "dimgui"
targetName "DImGui"
description "An example of calling imgui from D."
authors "Danny Arends"
copyright "Copyright © 2025, Danny Arends"
license "proprietary"
dflags "-P-I./deps/include/SDL2/"
dflags "-P-I./deps/cimgui/"
dflags "-P-I./deps/cimgui/imgui/"
lflags "-L./deps/lib/"
lflags "-L./"
lflags "-l:libSDL2.a"
lflags "-l:libSDL2_ttf.a"
lflags "-l:libSDL2_image.a"
lflags "-l:libcimgui.a"
lflags "-lvulkan"

