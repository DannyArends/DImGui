name "dimgui"
targetName "DImGui"
description "An example of calling imgui from D."
authors "Danny Arends"
copyright "Copyright © 2025, Danny Arends"
license "proprietary"
dflags "-P-I/usr/include/SDL2/"
dflags "-P-I./deps/cimgui/"
dflags "-P-I./deps/cimgui/imgui/"
lflags "-L./deps/lib/"
lflags "-L./"
lflags "-lSDL2"
lflags "-lSDL2_ttf"
lflags "-lSDL2_image"
lflags "-lSDL2_mixer"
lflags "-lcimgui"
lflags "-lvulkan"

