[submodule "deps/cimgui"]
	path = app/jni/cimgui
	url = https://github.com/cimgui/cimgui.git
[submodule "deps/shaderc"]
	path = app/jni/shaderc
	url = https://github.com/google/shaderc.git
[submodule "deps/spirv-cross"]
	path = app/jni/spirv_cross
	url = https://github.com/KhronosGroup/SPIRV-Cross.git
[submodule "deps/assimp"]
	path = app/jni/assimp
	url =  https://github.com/assimp/assimp.git
[submodule "app/jni/SDL"]
	path = app/jni/SDL
	url = https://github.com/libsdl-org/SDL
[submodule "app/jni/SDL_image"]
	path = app/jni/SDL_image
	url = https://github.com/libsdl-org/SDL_image
[submodule "app/jni/SDL_mixer"]
	path = app/jni/SDL_mixer
	url = https://github.com/libsdl-org/SDL_mixer
[submodule "app/jni/SDL_ttf"]
	path = app/jni/SDL_ttf
	url = https://github.com/libsdl-org/SDL_ttf
